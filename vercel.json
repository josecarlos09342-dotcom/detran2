{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/index\\.php",
      "dest": "/index.html"
    },
    {
      "src": "/debitos\\.php",
      "dest": "/debitos.html"
    },
    {
      "src": "/([^/]+\\.php)",
      "dest": "/api/$1"
    }
  ]
}
